{
  // Codespace 开发容器配置：CPU 环境，用于运行 Claude Code（第三方 API）
  "name": "AI API 开发环境",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",

  // 额外安装 Node.js（Claude Code 依赖 Node 18+）
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    }
  },

  // 容器创建后：装 Python 依赖 + 全局安装 Claude Code 和 Codex CLI + 让新终端自动加载 .env + 写入 Claude/Codex 默认设置
  "postCreateCommand": "pip install --upgrade pip && pip install -r requirements.txt && npm install -g @anthropic-ai/claude-code @openai/codex && echo 'set -a; [ -f ${containerWorkspaceFolder}/.env ] && . ${containerWorkspaceFolder}/.env; set +a' >> ~/.bashrc && mkdir -p ~/.claude && cp ${containerWorkspaceFolder}/.devcontainer/claude-settings.json ~/.claude/settings.json && mkdir -p ~/.codex && cp ${containerWorkspaceFolder}/.devcontainer/codex-config.toml ~/.codex/config.toml",

  // 第三方 API 的非敏感配置（地址和模型名可入库；令牌放本地 .env，不在这里）
  "containerEnv": {
    "ANTHROPIC_BASE_URL": "https://cc.freemodel.dev",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "claude-opus-4-8"
  },

  "customizations": {
    "vscode": {
      // 进入 Codespace 自动安装这些扩展
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-toolsai.jupyter"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python"
      }
    }
  }
}
