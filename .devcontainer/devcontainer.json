{
  // Codespace 开发容器配置：CPU 环境，用于调用云端大模型 API + 运行 Claude Code
  "name": "AI API 开发环境",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",

  // 额外安装 Node.js（Claude Code 依赖 Node 18+）
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    }
  },

  // 容器创建后：装 Python 依赖 + 全局安装 Claude Code
  "postCreateCommand": "pip install --upgrade pip && pip install -r requirements.txt && npm install -g @anthropic-ai/claude-code",

  // 第三方 API 的非敏感配置（地址和模型名可入库；令牌走 Codespaces Secret，不在这里）
  "containerEnv": {
    "ANTHROPIC_BASE_URL": "https://api-cc.freemodel.dev",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "claude-opus-4-8"
  },

  "customizations": {
    "vscode": {
      // 进入 Codespace 自动安装这些扩展
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-toolsai.jupyter"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python"
      }
    }
  }
}
